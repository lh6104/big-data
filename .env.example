# Copy to .env or .env.local and fill in local values.
# Do not commit real secrets.

# External APIs
TOMTOM_API_KEY=replace-with-tomtom-api-key
OWM_API_KEY=replace-with-openweather-api-key
OPENWEATHER_API_KEY=replace-with-openweather-api-key
TOMTOM_POLL_INTERVAL_MINUTES=5
WEATHER_POLL_INTERVAL_MINUTES=15

# Kafka / Schema Registry
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=events.news
SCHEMA_REGISTRY_URL=http://localhost:8081

# Redis / Postgres
REDIS_URL=redis://localhost:6379/0
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=traffic_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# AWS S3 lakehouse (plan v4 target)
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_REGION=ap-southeast-1
S3_BUCKET=cognitive-traffic-lakehouse
S3_WAREHOUSE=s3a://cognitive-traffic-lakehouse/warehouse
S3_ENDPOINT=

# MinIO / S3-compatible local fallback
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_BRONZE=warehouse

# Neo4j AuraDB cloud (plan v4 target)
NEO4J_URI=neo4j+s://replace-with-db-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-neo4j-password
NEO4J_DATABASE=neo4j

# Airflow local defaults
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_FERNET_KEY=replace-with-generated-fernet-key

# Geocoding / NLP
NOMINATIM_URL=http://localhost:8080
PHOBERT_CHECKPOINT=

# Local API / frontend
API_DATA_DIR=data
MODEL_DIR=models/artifacts
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
VITE_API_BASE_URL=http://localhost:8000
