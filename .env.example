# Copy to .env or .env.local and fill in local values.
# Do not commit real secrets.

# External APIs
TOMTOM_API_KEY=replace-with-tomtom-api-key
OWM_API_KEY=replace-with-openweather-api-key
OPENWEATHER_API_KEY=replace-with-openweather-api-key
TOMTOM_POLL_INTERVAL_MINUTES=5
WEATHER_POLL_INTERVAL_MINUTES=15

# Kafka / Schema Registry
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=events.news
SCHEMA_REGISTRY_URL=http://localhost:8081

# Redis / Postgres
REDIS_URL=redis://localhost:6379/0
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=traffic_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MinIO / S3-compatible lakehouse
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_BRONZE=warehouse

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Airflow local defaults
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_FERNET_KEY=replace-with-generated-fernet-key

# Geocoding / NLP
NOMINATIM_URL=http://localhost:8080
PHOBERT_CHECKPOINT=

# Local API / frontend
API_DATA_DIR=data
MODEL_DIR=models/artifacts
VITE_API_BASE_URL=http://localhost:8000
